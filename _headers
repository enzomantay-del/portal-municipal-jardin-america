# Cache del sitio — PC y celular deben ver lo mismo tras cada publicación.
# HTML, JS y CSS: sin caché larga en el navegador.

/
  Cache-Control: no-cache, no-store, must-revalidate
  Pragma: no-cache

/*.html
  Cache-Control: no-cache, no-store, must-revalidate
  Pragma: no-cache

/turismo/
  Cache-Control: no-cache, no-store, must-revalidate
  Pragma: no-cache

/turismo/*
  Cache-Control: no-cache, no-store, must-revalidate

/js/*
  Cache-Control: no-cache, no-store, must-revalidate
  Pragma: no-cache
  CDN-Cache-Control: no-cache, no-store, must-revalidate
  Netlify-CDN-Cache-Control: no-cache, no-store, must-revalidate

/css/*
  Cache-Control: no-cache, no-store, must-revalidate
  Pragma: no-cache
  CDN-Cache-Control: no-cache, no-store, must-revalidate
  Netlify-CDN-Cache-Control: no-cache, no-store, must-revalidate

/turismo/js/*
  Cache-Control: no-cache, no-store, must-revalidate
  Pragma: no-cache
  CDN-Cache-Control: no-cache, no-store, must-revalidate
  Netlify-CDN-Cache-Control: no-cache, no-store, must-revalidate

/turismo/css/*
  Cache-Control: no-cache, no-store, must-revalidate
  Pragma: no-cache
  CDN-Cache-Control: no-cache, no-store, must-revalidate
  Netlify-CDN-Cache-Control: no-cache, no-store, must-revalidate

/assets/*
  Cache-Control: public, max-age=86400, stale-while-revalidate=604800
